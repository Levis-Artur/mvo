NODE_ENV=production
POSTGRES_DB=mvo
POSTGRES_USER=mvo
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://mvo:CHANGE_ME@postgres:5432/mvo?schema=public
API_PORT=3001
WEB_PORT=3000
PUBLIC_PORT=80
NEXT_PUBLIC_API_URL=/api
CORS_ORIGIN=http://SERVER_IP
MAX_IMPORT_FILE_SIZE_MB=20
MAX_ATTACHMENT_FILE_SIZE_MB=10
# Must be at least the larger of import and attachment limits.
MAX_UPLOAD_FILE_SIZE_MB=20
STOCK_DOCUMENT_ATTACHMENTS_DIR=/app/data/stock-document-attachments
BACKUP_RETENTION_DAYS=30
OWNER_DESTRUCTIVE_ACTIONS_ENABLED=false
