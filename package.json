{
  "name": "mvo-inventory",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "prisma": "^6.12.0"
  },
  "scripts": {
    "dev": "concurrently -n API,WEB \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace apps/web",
    "build:api": "npm run build --workspace apps/api",
    "lint": "eslint .",
    "check": "npm run lint && npm run build",
    "clean": "rimraf apps/web/.next apps/api/dist",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:seed": "node apps/api/prisma/seed.mjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.31.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.31.0",
    "eslint-config-next": "^15.4.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  }
}
