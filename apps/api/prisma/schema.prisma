generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportType {
  INITIAL_BALANCE
  RECEIPT
}

enum ImportStatus {
  UPLOADED
  VALIDATED
  COMPLETED
  PARTIALLY_COMPLETED
  FAILED
  CANCELLED
  ROLLED_BACK
}

enum ImportRowStatus {
  VALID
  WARNING
  ERROR
  SKIPPED
  IMPORTED
}

enum StockTransactionType {
  INITIAL_BALANCE
  RECEIPT
  MANUAL_RECEIPT
  ADJUSTMENT_INCREASE
  ADJUSTMENT_DECREASE
  TRANSFER_OUT
  TRANSFER_IN
  ISSUE
  TRANSFER_REVERSAL_OUT
  TRANSFER_REVERSAL_IN
  ISSUE_REVERSAL
}

enum StockDocumentType {
  TRANSFER
  ISSUE
}

enum StockDocumentStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum InventoryItemReviewStatus {
  VERIFIED
  NEEDS_REVIEW
}

enum UserRole {
  OWNER
  AUDITOR
  DPP_ADMIN
  MVO
}

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  PASSWORD_CHANGED
  PASSWORD_RESET
  USER_CREATED
  USER_UPDATED
  USER_BLOCKED
  USER_UNBLOCKED
  USER_ACTIVATED
  USER_DEACTIVATED
  ROLE_CHANGED
  SESSIONS_REVOKED
  ACCESS_DENIED
  OWNER_DESTRUCTIVE_ACTION
  STOCK_DOCUMENT_ACTION
}

model Management {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  shortName          String?
  code               String              @unique
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  services           Service[]
  responsiblePersons ResponsiblePerson[]

  @@index([isActive])
}

model Service {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  code               String
  managementId       String              @db.Uuid
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  management         Management          @relation(fields: [managementId], references: [id], onDelete: Restrict)
  units              Unit[]
  responsiblePersons ResponsiblePerson[]

  @@unique([managementId, code])
  @@index([managementId])
  @@index([isActive])
}

model Unit {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  code               String
  serviceId          String              @db.Uuid
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  service            Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  responsiblePersons ResponsiblePerson[]

  @@unique([serviceId, code])
  @@index([serviceId])
  @@index([isActive])
}

model ResponsiblePerson {
  id                     String             @id @default(uuid()) @db.Uuid
  lastName               String
  firstName              String
  middleName             String?
  personnelNumber        String             @unique
  position               String?
  phone                  String?
  email                  String?
  externalAccountingName String?            @unique
  externalAccountingCode String?
  managementId           String             @db.Uuid
  serviceId              String             @db.Uuid
  unitId                 String?            @db.Uuid
  appointmentOrderNumber String?
  appointmentDate        DateTime?
  isActive               Boolean            @default(true)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  management             Management         @relation(fields: [managementId], references: [id], onDelete: Restrict)
  service                Service            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  unit                   Unit?              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  stockBalances          StockBalance[]
  stockTransactions      StockTransaction[]
  importRows             ImportRow[]
  user                   User?
  sourceStockDocuments   StockDocument[]    @relation("StockDocumentSource")
  destinationStockDocuments StockDocument[] @relation("StockDocumentDestination")

  @@index([managementId])
  @@index([serviceId])
  @@index([unitId])
  @@index([isActive])
  @@index([lastName])
  @@index([firstName])
  @@index([middleName])
  @@index([personnelNumber])
  @@index([externalAccountingCode])
}

model User {
  id                   String             @id @default(uuid()) @db.Uuid
  username             String             @unique
  passwordHash         String
  role                 UserRole
  isActive             Boolean            @default(true)
  mustChangePassword   Boolean            @default(true)
  failedLoginAttempts  Int                @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  passwordChangedAt    DateTime?
  responsiblePersonId  String?            @unique @db.Uuid
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  createdById          String?            @db.Uuid
  responsiblePerson    ResponsiblePerson? @relation(fields: [responsiblePersonId], references: [id], onDelete: Restrict)
  createdBy            User?              @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers         User[]             @relation("UserCreatedBy")
  sessions             UserSession[]
  actorSecurityEvents  SecurityEvent[]    @relation("SecurityEventActor")
  targetSecurityEvents SecurityEvent[]    @relation("SecurityEventTarget")
  createdStockDocuments   StockDocument[]  @relation("StockDocumentCreatedBy")
  postedStockDocuments    StockDocument[]  @relation("StockDocumentPostedBy")
  cancelledStockDocuments StockDocument[]  @relation("StockDocumentCancelledBy")

  @@index([role])
  @@index([isActive])
  @@index([createdById])
  @@index([responsiblePersonId])
}

model UserSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model SecurityEvent {
  id           String            @id @default(uuid()) @db.Uuid
  type         SecurityEventType
  actorUserId  String?           @db.Uuid
  targetUserId String?           @db.Uuid
  ipAddress    String?
  userAgent    String?
  requestId    String?
  metadata     Json?
  success      Boolean
  createdAt    DateTime          @default(now())
  actorUser    User?             @relation("SecurityEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser   User?             @relation("SecurityEventTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([createdAt])
  @@index([success])
}

model InventoryItem {
  id                String                    @id @default(uuid()) @db.Uuid
  externalCode      String                    @unique
  name              String
  unitOfMeasure     String?
  category          String?
  description       String?
  reviewStatus      InventoryItemReviewStatus @default(NEEDS_REVIEW)
  isActive          Boolean                   @default(true)
  createdManually   Boolean                   @default(false)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  stockBalances     StockBalance[]
  stockTransactions StockTransaction[]
  importRows        ImportRow[]
  stockDocumentLines StockDocumentLine[]

  @@index([name])
  @@index([reviewStatus])
  @@index([isActive])
}

model StockBalance {
  id                  String            @id @default(uuid()) @db.Uuid
  responsiblePersonId String            @db.Uuid
  inventoryItemId     String            @db.Uuid
  quantity            Decimal           @default(0) @db.Decimal(18, 4)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  responsiblePerson   ResponsiblePerson @relation(fields: [responsiblePersonId], references: [id], onDelete: Restrict)
  inventoryItem       InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([responsiblePersonId, inventoryItemId])
  @@index([responsiblePersonId])
  @@index([inventoryItemId])
}

model StockTransaction {
  id                  String               @id @default(uuid()) @db.Uuid
  type                StockTransactionType
  responsiblePersonId String               @db.Uuid
  inventoryItemId     String               @db.Uuid
  quantity            Decimal              @db.Decimal(18, 4)
  balanceBefore       Decimal              @db.Decimal(18, 4)
  balanceAfter        Decimal              @db.Decimal(18, 4)
  occurredAt          DateTime
  comment             String?
  sourceDocument      String?
  importBatchId       String?              @db.Uuid
  importRowId         String?              @unique @db.Uuid
  documentId          String?              @db.Uuid
  documentLineId      String?              @db.Uuid
  createdAt           DateTime             @default(now())
  responsiblePerson   ResponsiblePerson    @relation(fields: [responsiblePersonId], references: [id], onDelete: Restrict)
  inventoryItem       InventoryItem        @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  importBatch         ImportBatch?         @relation(fields: [importBatchId], references: [id], onDelete: Restrict)
  importRow           ImportRow?           @relation(fields: [importRowId], references: [id], onDelete: Restrict)
  document            StockDocument?       @relation(fields: [documentId], references: [id], onDelete: Restrict)
  documentLine        StockDocumentLine?   @relation(fields: [documentLineId], references: [id], onDelete: Restrict)

  @@index([responsiblePersonId])
  @@index([inventoryItemId])
  @@index([type])
  @@index([occurredAt])
  @@index([importBatchId])
  @@index([documentId])
  @@index([documentLineId])
}

model StockDocument {
  id                             String              @id @default(uuid()) @db.Uuid
  documentNumber                 String              @unique
  documentDate                   DateTime
  type                           StockDocumentType
  status                         StockDocumentStatus @default(DRAFT)
  sourceResponsiblePersonId      String              @db.Uuid
  destinationResponsiblePersonId String?             @db.Uuid
  recipientName                  String?
  recipientUnit                  String?
  basis                          String?
  note                           String?
  createdByUserId                String              @db.Uuid
  postedByUserId                 String?             @db.Uuid
  postedAt                       DateTime?
  cancelledByUserId              String?             @db.Uuid
  cancelledAt                    DateTime?
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt
  sourceResponsiblePerson        ResponsiblePerson   @relation("StockDocumentSource", fields: [sourceResponsiblePersonId], references: [id], onDelete: Restrict)
  destinationResponsiblePerson   ResponsiblePerson?  @relation("StockDocumentDestination", fields: [destinationResponsiblePersonId], references: [id], onDelete: Restrict)
  createdByUser                  User                @relation("StockDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  postedByUser                   User?               @relation("StockDocumentPostedBy", fields: [postedByUserId], references: [id], onDelete: Restrict)
  cancelledByUser                User?               @relation("StockDocumentCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: Restrict)
  lines                          StockDocumentLine[]
  transactions                   StockTransaction[]

  @@index([type])
  @@index([status])
  @@index([documentDate])
  @@index([sourceResponsiblePersonId])
  @@index([destinationResponsiblePersonId])
  @@index([createdByUserId])
}

model StockDocumentLine {
  id              String             @id @default(uuid()) @db.Uuid
  documentId      String             @db.Uuid
  inventoryItemId String             @db.Uuid
  quantity        Decimal            @db.Decimal(18, 4)
  note            String?
  createdAt       DateTime           @default(now())
  document        StockDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  transactions    StockTransaction[]

  @@unique([documentId, inventoryItemId])
  @@index([documentId])
  @@index([inventoryItemId])
}

model ImportBatch {
  id               String             @id @default(uuid()) @db.Uuid
  type             ImportType
  status           ImportStatus       @default(UPLOADED)
  originalFilename String
  fileHash         String             @unique
  fileSize         Int
  encoding         String
  delimiter        String
  totalRows        Int                @default(0)
  validRows        Int                @default(0)
  warningRows      Int                @default(0)
  errorRows        Int                @default(0)
  skippedRows      Int                @default(0)
  importedRows     Int                @default(0)
  periodStart      DateTime?
  periodEnd        DateTime?
  createdAt        DateTime           @default(now())
  validatedAt      DateTime?
  completedAt      DateTime?
  rows             ImportRow[]
  transactions     StockTransaction[]

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model ImportRow {
  id                  String             @id @default(uuid()) @db.Uuid
  importBatchId       String             @db.Uuid
  rowNumber           Int
  status              ImportRowStatus
  counterpartyRaw     String
  nomenclatureCodeRaw String
  itemNameRaw         String
  unitOfMeasureRaw    String?
  debitQuantityRaw    String?
  endingQuantityRaw   String?
  parsedQuantity      Decimal?           @db.Decimal(18, 4)
  responsiblePersonId String?            @db.Uuid
  inventoryItemId     String?            @db.Uuid
  message             String?
  systemBalance       Decimal?           @db.Decimal(18, 4)
  fileEndingBalance   Decimal?           @db.Decimal(18, 4)
  balanceDifference   Decimal?           @db.Decimal(18, 4)
  createdAt           DateTime           @default(now())
  importBatch         ImportBatch        @relation(fields: [importBatchId], references: [id], onDelete: Restrict)
  responsiblePerson   ResponsiblePerson? @relation(fields: [responsiblePersonId], references: [id], onDelete: Restrict)
  inventoryItem       InventoryItem?     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  stockTransaction    StockTransaction?

  @@unique([importBatchId, rowNumber])
  @@index([importBatchId])
  @@index([status])
  @@index([responsiblePersonId])
  @@index([inventoryItemId])
}
